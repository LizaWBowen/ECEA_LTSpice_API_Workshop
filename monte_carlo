import numpy as np
import json
from PyLTSpice import SimRunner, AscEditor, RawRead

LTSPICE_EXE = r"C:\Program Files\ADI\LTspice\LTspice.exe"
SCHEMATIC = r"schematics\rc_lowpass.asc"

OUTPUT_FILE = r"output\reports\montecarlo_results.json"

NUM_SIMULATIONS = 200

R_nominal = 10000
C_nominal = 100e-9

R_tol = 0.05
C_tol = 0.10

editor = AscEditor(SCHEMATIC)
runner = SimRunner(output_folder="output/sim_output", simulator=LTSPICE_EXE)

results = []

for i in range(NUM_SIMULATIONS):

    R = np.random.normal(R_nominal, R_nominal * R_tol)
    C = np.random.normal(C_nominal, C_nominal * C_tol)

    editor.set_component_value("R1", str(R))
    editor.set_component_value("C1", str(C))

    temp_file = f"output/sim_output/temp_{i}.asc"
    editor.save_netlist(temp_file)

    raw_file, log_file = runner.run_now(temp_file)

    raw = RawRead(raw_file)

    freq = raw.get_axis()
    vout = raw.get_trace("V(out)").get_wave()

    mag = np.abs(vout)

    target = 1 / np.sqrt(2)

    idx = np.argmin(np.abs(mag - target))

    cutoff_freq = float(freq[idx])

    results.append({
        "R": float(R),
        "C": float(C),
        "cutoff": cutoff_freq
    })

with open(OUTPUT_FILE, "w") as f:
    json.dump(results, f, indent=2)

print("Monte Carlo simulation complete.")
